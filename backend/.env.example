# ===========================================
# Facebook Posting — copy this file to .env
#   copy backend\.env.example backend\.env
# Fill in values below, then run setup.bat once.
# ===========================================

# ===========================================
# Admin Login — optional here; can set on first visit at http://localhost:5174
# ===========================================
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ===========================================
# App Settings — local SQLite (no cloud DB)
# ===========================================
SECRET_KEY=change-this-secret-key-in-production-use-long-random-string
DATABASE_URL=sqlite:///./data/facebook_posting.db
API_PORT=8002
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# ===========================================
# SMTP — Backend only (NOT shown in dashboard)
# Gmail: enable 2FA, create App Password
# Used for login reminder emails if Facebook session expires
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Facebook Posting
SMTP_USE_TLS=true

# ===========================================
# Facebook posting — Italy timezone & scheduling
# ===========================================
# Scheduling uses Europe/Rome (Italy). Do not change unless instructed.
BROWSER_TIMEZONE=Europe/Rome
BROWSER_LOCALE=it-IT
FACEBOOK_ORIGIN=https://it-it.facebook.com

# Required for scheduled posting app:
# - Bot wait loop handles one product at a time (queue)
# - No duplicate 60s scheduler publish job
# - Stays on Marketplace after login (no monitoring scrape)
STOP_AFTER_MARKETPLACE=true

# Chromium opens visible on Start (required for manual Facebook login)
PLAYWRIGHT_HEADLESS=false

# Session & browser profile paths (relative to backend/)
FACEBOOK_SESSION_FILE=data/facebook_session.json
FACEBOOK_PROFILE_DIR=data/facebook_chrome_profile
